{
  "name": "raylimit-docs-site",
  "private": true,
  "version": "0.3.0-beta",
  "scripts": {
    "assets": "node scripts/generate-brand-assets.mjs",
    "build": "next build",
    "build:static": "GHPAGES=1 next build",
    "dev": "next dev",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md,mdx}\" \"../README.md\" \"../.github/workflows/docs.yml\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md,mdx}\" \"../README.md\" \"../.github/workflows/docs.yml\"",
    "prebuild": "npm run assets",
    "prebuild:static": "npm run assets",
    "predev": "npm run assets",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^13.5.6",
    "nextra": "^2.13.4",
    "nextra-theme-docs": "^2.13.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "18.15.11",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.21",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.1",
    "typescript": "^5.5.0"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "endOfLine": "lf",
    "semi": true,
    "singleQuote": true,
    "jsxSingleQuote": false,
    "bracketSameLine": true,
    "printWidth": 100
  }
}
